APP_NAME="Recommendation System"
DEBUG=false

# Supabase PostgreSQL connection string
# Find this in: Supabase dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# For transaction pooler (recommended for serverless/Render):
# DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

CORS_ORIGINS=["http://localhost:3000","https://your-frontend.onrender.com"]
MODEL_DIR=./model_artifacts
LOG_LEVEL=INFO
